# ==================== 服务器配置 ====================
NODE_ENV=development
PORT=3000
HOST=0.0.0.0

# ==================== 数据库配置 (Supabase PostgreSQL) ====================
# 在 Supabase 控制台 → Project Settings → Database → Connection string → URI
# 格式: postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres
DATABASE_URL="postgresql://postgres.xxxx:your-password@aws-0-ap-southeast-1.pooler.supabase.com:6543/postgres"

# ==================== Redis 配置 (Upstash) ====================
# 在 Upstash 控制台 → Redis Database → Details → REST API 中获取
# Upstash 强制 TLS 连接，Redis Service 会自动启用
REDIS_HOST=your-redis.upstash.io
REDIS_PORT=6379
REDIS_PASSWORD=your-upstash-redis-password
REDIS_DB=0
# Upstash 必须 TLS，service 代码已自动处理
REDIS_TLS=true

# ==================== JWT 配置 ====================
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# ==================== 微信小程序配置 (H5 版本可选) ====================
WECHAT_APPID=
WECHAT_SECRET=

# ==================== 腾讯云 TRTC 配置 (已废弃，H5 版不用) ====================
# TRTC_SDK_APPID=
# TRTC_SECRET_KEY=
# TRTC_EXPIRE_TIME=86400

# ==================== 业务配置 ====================
MAX_ROOMS_PER_USER=10
ROOM_CODE_POOL_SIZE=100000
HEARTBEAT_INTERVAL=5000
HEARTBEAT_TIMEOUT=15000
MAX_CONNECTIONS_PER_USER=1
CLAIM_WINDOW_MS=5000

# ==================== CORS 配置 ====================
CORS_ORIGIN=*

# ==================== 节点标识 ====================
HOSTNAME=node-1

# ==================== 前端部署地址（供前后端通信） ====================
# TARO_APP_API_URL=http://localhost:3000
# TARO_APP_WS_URL=http://localhost:3000
